---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Mitarbeiterverwaltung für Kliniken — Zeiterfassung, Dienstplan und mehr.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — MVA Mitarbeiterverwaltung</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 font-sans">

    <!-- Header / Navigation -->
    <header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

          <!-- Logo -->
          <a href={`${base}/`} class="flex items-center gap-2 font-bold text-xl text-blue-700 hover:text-blue-900 transition-colors">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            MVA
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-6">
            <a href={`${base}/`} class="text-gray-600 hover:text-blue-700 font-medium transition-colors">Start</a>
            <a href={`${base}/#features`} class="text-gray-600 hover:text-blue-700 font-medium transition-colors">Features</a>
            <a href={`${base}/#preise`} class="text-gray-600 hover:text-blue-700 font-medium transition-colors">Preise</a>
            <a href={`${base}/handbuch`} class="text-gray-700 hover:text-blue-700 font-medium transition-colors border-b-2 border-transparent hover:border-blue-600">
              Handbuch
            </a>
            <a href="https://mva.c3po42.de" target="_blank" rel="noopener"
              class="ml-2 bg-blue-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-blue-700 transition-colors text-sm">
              Zur App →
            </a>
          </nav>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 rounded-md text-gray-600 hover:text-blue-700 hover:bg-gray-100" aria-label="Menü öffnen">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Nav -->
      <div id="mobile-menu" class="md:hidden hidden border-t border-gray-100 bg-white px-4 py-3 space-y-2">
        <a href={`${base}/`} class="block text-gray-700 hover:text-blue-700 font-medium py-1">Start</a>
        <a href={`${base}/#features`} class="block text-gray-700 hover:text-blue-700 font-medium py-1">Features</a>
        <a href={`${base}/#preise`} class="block text-gray-700 hover:text-blue-700 font-medium py-1">Preise</a>
        <a href={`${base}/handbuch`} class="block text-blue-700 font-semibold py-1">Handbuch</a>
        <a href="https://mva.c3po42.de" target="_blank" rel="noopener"
          class="block bg-blue-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-blue-700 text-center">
          Zur App →
        </a>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-10 mt-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="text-sm">
            © 2026 MVA Mitarbeiterverwaltung · Ilm-Kreis-Kliniken
          </div>
          <div class="flex gap-6 text-sm">
            <a href={`${base}/handbuch`} class="hover:text-white transition-colors">Handbuch</a>
            <a href="https://mva.c3po42.de" target="_blank" rel="noopener" class="hover:text-white transition-colors">App öffnen</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
