---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Mitarbeiterverwaltung für Kliniken">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-700 to-blue-900 text-white py-24 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">
        Mitarbeiterverwaltung<br />für Kliniken
      </h1>
      <p class="text-xl text-blue-100 mb-10 max-w-2xl mx-auto">
        Zeiterfassung, Dienstplanung, Abwesenheiten und Kommunikation —
        alles in einer Anwendung für Ihre Klinik.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://mva.c3po42.de" target="_blank" rel="noopener"
          class="bg-white text-blue-700 px-8 py-3 rounded-xl font-bold text-lg hover:bg-blue-50 transition-colors shadow-lg">
          Zur App →
        </a>
        <a href={`${base}/handbuch`}
          class="border-2 border-white text-white px-8 py-3 rounded-xl font-bold text-lg hover:bg-white hover:text-blue-700 transition-colors">
          Benutzerhandbuch
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12 text-gray-900">Alle wichtigen Funktionen</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { icon: '⏱', title: 'Zeiterfassung', desc: 'Ein- und Ausstempeln per Klick. Automatische Pausenberechnung nach ArbZG.' },
          { icon: '📅', title: 'Dienstplanung', desc: 'Übersichtliche Kalendaransicht. Schichten per Drag & Drop zuweisen.' },
          { icon: '🏖', title: 'Abwesenheiten', desc: 'Urlaubsanträge, Krankmeldungen und Sonderurlaub digital beantragen.' },
          { icon: '💬', title: 'Chat', desc: 'Interne Kommunikation per Direktnachricht und Gruppenchat.' },
          { icon: '📊', title: 'Auswertungen', desc: 'Monatsberichte, CSV-Export für LOGA und Jahresübersichten.' },
          { icon: '📱', title: 'Android-App', desc: 'Native App mit Biometrie-Login für unterwegs.' },
        ].map(f => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="text-4xl mb-4">{f.icon}</div>
            <h3 class="text-xl font-semibold mb-2 text-gray-900">{f.title}</h3>
            <p class="text-gray-600">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Preise -->
  <section id="preise" class="py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-6 text-gray-900">Für Ihre Klinik</h2>
      <p class="text-gray-600 text-lg mb-8">
        Die MVA-Anwendung wird individuell für Ihre Einrichtung konfiguriert und betrieben.
        Kontaktieren Sie uns für ein maßgeschneidertes Angebot.
      </p>
      <a href="mailto:it@ilm-kreis-kliniken.de"
        class="inline-block bg-blue-600 text-white px-8 py-3 rounded-xl font-bold text-lg hover:bg-blue-700 transition-colors">
        Kontakt aufnehmen
      </a>
    </div>
  </section>

</Layout>
