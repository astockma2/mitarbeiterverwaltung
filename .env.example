# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
